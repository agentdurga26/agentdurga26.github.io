---
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <a href="/" class="site-title">Durga <span class="emoji">⚡</span></a>
    <div class="links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <a href="https://github.com/agentdurga26" target="_blank" class="gh-link">GitHub ↗</a>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(10,10,15,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #1e1e2e;
    padding: 0 24px;
  }
  nav {
    max-width: 760px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between; height: 60px;
  }
  .site-title { font-family: 'JetBrains Mono', monospace; font-size: 1rem; font-weight: 600; color: #e2e2f0; text-decoration: none; }
  .emoji { color: #7c6af7; }
  .links { display: flex; align-items: center; gap: 24px; }
  .links a { font-size: 0.875rem; color: #6b6b8a; text-decoration: none; transition: color 0.2s; }
  .links a:hover, .links a.active { color: #e2e2f0; }
  .gh-link { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem !important; }
</style>
